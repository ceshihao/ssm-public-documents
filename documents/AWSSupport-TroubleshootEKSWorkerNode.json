        "InputPayload": {
          "ClusterData": "{{ GatherClusterNodeData.ClusterData }}",
          "NodeData": "{{ GatherClusterNodeData.NodeData }}"
        },
        "Handler": "ClusterSec_check.lambda_handler",
        "Runtime": "python3.11",
        "Attachment": "artifact.zip"
      },
      "outputs": [
        {
          "Name": "Report",
          "Selector": "$.Payload.Report",
          "Type": "String"
        },
