{
  "schemaVersion": "1.0",
  "description": "Amazon Bedrock Security and Governance best practices",
  "templateBody": {
    "Parameters": {
      "ApiGwEndpointConfigurationTypes": {
        "Type": "String",
        "Default": "PRIVATE"
      }
    },
    "Resources": {
      "GuardrailStatusCheck": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-guardrail-status",
          "Description": "Ensures Bedrock Guardrails are operational to enforce content filtering and responsible AI policies",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "PolicyText": "rule check { configuration.Status in [\"READY\", \"VERSIONED\"] \n  <<\n    Violation: Guardrail must be READY or VERSIONED\n    Fix: Check resource state and resolve issues\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::Bedrock::Guardrail"
            ]
          }
        }
      },
      "GuardrailRequiredTags": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-guardrail-tags",
          "Description": "Ensures Bedrock Guardrails have governance tags for responsible AI tracking and ownership",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "PolicyText": "rule check { \n  configuration.Tags exists\n  some configuration.Tags[*].Key == \"Environment\"\n  some configuration.Tags[*].Key == \"DataClassification\"\n  some configuration.Tags[*].Key == \"OwnerTeam\"\n\n  <<\n    Violation: Missing required governance tags\n    Fix: Add Environment, DataClassification, OwnerTeam tags\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::Bedrock::Guardrail"
            ]
          }
        }
      },
      "KBStatusCheck": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-kb-status",
          "Description": "Ensures Bedrock Knowledge Bases are ACTIVE for RAG-based AI/ML workloads",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "PolicyText": "rule check { configuration.Status == \"ACTIVE\" \n  <<\n    Violation: Knowledge Base must be ACTIVE\n    Fix: Check resource state and resolve issues\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::Bedrock::KnowledgeBase"
            ]
          }
        }
      },
      "KBRequiredTags": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-kb-tags",
          "Description": "Ensures Bedrock Knowledge Bases have governance tags for AI/ML data lineage and ownership",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "PolicyText": "rule check { \n  configuration.Tags exists\n  configuration.Tags.Environment exists\n  configuration.Tags.DataClassification exists\n  configuration.Tags.OwnerTeam exists\n\n  <<\n    Violation: Missing required governance tags\n    Fix: Add Environment, DataClassification, OwnerTeam tags\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::Bedrock::KnowledgeBase"
            ]
          }
        }
      },
      "PromptRequiredTags": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-prompt-tags",
          "Description": "Ensures Bedrock Prompts have governance tags for prompt versioning and AI/ML audit trails",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "PolicyText": "rule check { \n  configuration.Tags exists\n  configuration.Tags.Environment exists\n  configuration.Tags.DataClassification exists\n  configuration.Tags.OwnerTeam exists\n\n  <<\n    Violation: Missing required governance tags\n    Fix: Add Environment, DataClassification, OwnerTeam tags\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::Bedrock::Prompt"
            ]
          }
        }
      },
      "ProfileStatusCheck": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-profile-status",
          "Description": "Ensures Bedrock Application Inference Profiles are ACTIVE for AI/ML model routing",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "PolicyText": "rule check { configuration.Status == \"ACTIVE\" \n  <<\n    Violation: Application Profile must be ACTIVE\n    Fix: Check resource state and resolve issues\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::Bedrock::ApplicationInferenceProfile"
            ]
          }
        }
      },
      "ProfileRequiredTags": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-profile-tags",
          "Description": "Ensures Bedrock Inference Profiles have governance tags for AI/ML cost allocation and ownership",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "PolicyText": "rule check { \n  configuration.Tags exists\n  some configuration.Tags[*].Key == \"Environment\"\n  some configuration.Tags[*].Key == \"DataClassification\"\n  some configuration.Tags[*].Key == \"OwnerTeam\"\n\n  <<\n    Violation: Missing required governance tags\n    Fix: Add Environment, DataClassification, OwnerTeam tags\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::Bedrock::ApplicationInferenceProfile"
            ]
          }
        }
      },
      "RuntimeVPC": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-runtime-vpc",
          "Description": "Ensures Bedrock Runtime is deployed in a VPC for AI/ML network isolation",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "PolicyText": "rule check { \n  configuration.NetworkConfiguration.NetworkModeConfig exists\n  configuration.NetworkConfiguration.NetworkModeConfig.VpcId exists\n\n  <<\n    Violation: Runtime must be in VPC\n    Fix: Configure VPC settings\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::BedrockAgentCore::Runtime"
            ]
          }
        }
      },
      "RuntimeSG": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-runtime-security-groups",
          "Description": "Ensures Bedrock Runtime has security groups to control AI/ML agent network access",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "PolicyText": "rule check { \n  configuration.NetworkConfiguration.NetworkModeConfig.SecurityGroups exists\n  configuration.NetworkConfiguration.NetworkModeConfig.SecurityGroups not empty\n\n  <<\n    Violation: Runtime must have security groups\n    Fix: Attach security groups\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::BedrockAgentCore::Runtime"
            ]
          }
        }
      },
      "BrowserVPC": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-browser-vpc",
          "Description": "Ensures Bedrock Browser is deployed in a VPC for secure AI/ML web browsing isolation",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "PolicyText": "rule check { \n  configuration.NetworkConfiguration.VpcConfig exists\n  configuration.NetworkConfiguration.VpcConfig.VpcId exists\n\n  <<\n    Violation: Browser must be in VPC\n    Fix: Configure VPC settings\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::BedrockAgentCore::BrowserCustom"
            ]
          }
        }
      },
      "BrowserSG": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-browser-security-groups",
          "Description": "Ensures Bedrock Browser has security groups to control AI agent web access",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "PolicyText": "rule check { \n  configuration.NetworkConfiguration.VpcConfig.SecurityGroups exists\n  configuration.NetworkConfiguration.VpcConfig.SecurityGroups not empty\n\n  <<\n    Violation: Browser must have security groups\n    Fix: Attach security groups\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::BedrockAgentCore::BrowserCustom"
            ]
          }
        }
      },
      "BrowserRequiredTags": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-browser-tags",
          "Description": "Ensures Bedrock Browser has governance tags for AI agent browsing audit and ownership",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "PolicyText": "rule check { \n  configuration.Tags exists\n  configuration.Tags.Environment exists\n  configuration.Tags.DataClassification exists\n  configuration.Tags.OwnerTeam exists\n\n  <<\n    Violation: Missing required governance tags\n    Fix: Add Environment, DataClassification, OwnerTeam tags\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::BedrockAgentCore::BrowserCustom"
            ]
          }
        }
      },
      "DataSourceStatusCheck": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-datasource-status",
          "Description": "Ensures Bedrock Data Sources are AVAILABLE for RAG knowledge ingestion",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "EnableDebugLogDelivery": true,
              "PolicyText": "rule check { \n  configuration.DataSourceStatus == \"AVAILABLE\"\n  <<\n    Violation: Data Source must be AVAILABLE\n    Fix: Investigate and resolve data source issues\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::Bedrock::DataSource"
            ]
          }
        }
      },
      "DataSourceDeletionPolicyCheck": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-datasource-retain-policy",
          "Description": "Prevents accidental deletion of RAG knowledge data by enforcing RETAIN policy on Bedrock data sources",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "EnableDebugLogDelivery": true,
              "PolicyText": "rule check { \n  configuration.DataDeletionPolicy == \"RETAIN\"\n  <<\n    Violation: Data Source deletion policy must be RETAIN\n    Fix: Set DataDeletionPolicy to RETAIN to prevent data loss\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::Bedrock::DataSource"
            ]
          }
        }
      },
      "DataSourceNoFailures": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-datasource-no-failures",
          "Description": "Ensures Bedrock Data Sources have no ingestion failures affecting RAG quality",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "EnableDebugLogDelivery": true,
              "PolicyText": "rule check { \n  configuration.FailureReasons empty\n  <<\n    Violation: Data Source has failure reasons\n    Fix: Investigate and resolve data source failures\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::Bedrock::DataSource"
            ]
          }
        }
      },
      "GatewayStatusCheck": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-gateway-status",
          "Description": "Ensures Bedrock AgentCore Gateways are READY for AI agent API routing",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "EnableDebugLogDelivery": true,
              "PolicyText": "rule check { \n  configuration.Status == \"READY\"\n  <<\n    Violation: Gateway must be READY\n    Fix: Complete gateway configuration\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::BedrockAgentCore::Gateway"
            ]
          }
        }
      },
      "GatewayAuthorizerRequired": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-gateway-authorizer",
          "Description": "Ensures Bedrock Gateways have an authorizer to control AI agent API access",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "EnableDebugLogDelivery": true,
              "PolicyText": "rule check { \n  configuration.AuthorizerType != \"NONE\"\n  <<\n    Violation: No authorizer configured\n    Fix: Set AuthorizerType to CUSTOM\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::BedrockAgentCore::Gateway"
            ]
          }
        }
      },
      "GatewayRequiredTags": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-gateway-tags",
          "Description": "Ensures Bedrock Gateways have governance tags for AI agent endpoint tracking and ownership",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "EnableDebugLogDelivery": true,
              "PolicyText": "rule check { \n  configuration.Tags exists\n  configuration.Tags.Environment exists\n  configuration.Tags.DataClassification exists\n  configuration.Tags.OwnerTeam exists\n  <<\n    Violation: Missing required governance tags\n    Fix: Add Environment, DataClassification, OwnerTeam tags\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::BedrockAgentCore::Gateway"
            ]
          }
        }
      },
      "MemoryStatusCheck": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-memory-status",
          "Description": "Ensures Bedrock Memory is ACTIVE for AI agent conversation persistence",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "EnableDebugLogDelivery": true,
              "PolicyText": "rule check { \n  configuration.Status == \"ACTIVE\"\n  <<\n    Violation: Memory must be ACTIVE\n    Fix: Check resource state and resolve issues\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::BedrockAgentCore::Memory"
            ]
          }
        }
      },
      "MemoryEventExpiryCheck": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-memory-event-expiry",
          "Description": "Ensures Bedrock Memory has a TTL to limit PII and sensitive data retention in AI agent sessions",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "EnableDebugLogDelivery": true,
              "PolicyText": "rule check { \n  configuration.EventExpiryDuration exists\n  configuration.EventExpiryDuration > 0\n  <<\n    Violation: No event expiry configured\n    Fix: Set EventExpiryDuration > 0\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::BedrockAgentCore::Memory"
            ]
          }
        }
      },
      "MemoryRequiredTags": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-bedrock-memory-tags",
          "Description": "Ensures Bedrock Memory has governance tags for AI agent data retention compliance",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "EnableDebugLogDelivery": true,
              "PolicyText": "rule check { \n  configuration.Tags exists\n  configuration.Tags.Environment exists\n  configuration.Tags.DataClassification exists\n  configuration.Tags.OwnerTeam exists\n  <<\n    Violation: Missing required governance tags\n    Fix: Add Environment, DataClassification, OwnerTeam tags\n  >>\n}\n"
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::BedrockAgentCore::Memory"
            ]
          }
        }
      },
      "OpenSearchServerlessVectorSearchType": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "aiml-oss-vectorsearch-type",
          "Description": "Ensures OpenSearch Serverless collections use VECTORSEARCH type for RAG and embedding workloads",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "PolicyText": "rule check { \n  configuration.Type == \"VECTORSEARCH\"\n  <<\n    Violation: Collection must be VECTORSEARCH type for AI/ML workloads\n    Fix: Use VECTORSEARCH collection type\n  >>\n}\n",
              "EnableDebugLogDelivery": true
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::OpenSearchServerless::Collection"
            ]
          }
        }
      },
      "OpenSearchServerlessCustomerKMS": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "opensearch-serverless-customer-kms",
          "Description": "Ensures OpenSearch Serverless collections are encrypted with customer-managed KMS keys",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "PolicyText": "rule check { \n  configuration.EncryptionPolicy exists\n  configuration.EncryptionPolicy.KmsKeyArn exists\n  configuration.EncryptionPolicy.KmsKeyArn != \"\"\n  <<\n    Violation: Collection must use customer-managed KMS key\n    Fix: Configure encryption policy with customer KMS key\n  >>\n}\n",
              "EnableDebugLogDelivery": true
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::OpenSearchServerless::Collection"
            ]
          }
        }
      },
      "OpenSearchServerlessStandbyReplicas": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "opensearch-serverless-standby-replicas",
          "Description": "Ensures OpenSearch Serverless collections have standby replicas for high availability",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "PolicyText": "rule check { \n  configuration.StandbyReplicas == \"ENABLED\"\n  <<\n    Violation: Collection must have standby replicas enabled for HA\n    Fix: Enable standby replicas\n  >>\n}\n",
              "EnableDebugLogDelivery": true
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::OpenSearchServerless::Collection"
            ]
          }
        }
      },
      "OpenSearchSecurityConfigSessionTimeout": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "opensearch-securityconfig-session-timeout",
          "Description": "Limits OpenSearch Serverless SAML session duration to 60 minutes to reduce session hijack risk",
          "Source": {
            "Owner": "CUSTOM_POLICY",
            "SourceDetails": [
              {
                "EventSource": "aws.config",
                "MessageType": "ConfigurationItemChangeNotification"
              }
            ],
            "CustomPolicyDetails": {
              "PolicyRuntime": "guard-2.x.x",
              "PolicyText": "rule check { \n  configuration.SamlOptions.SessionTimeout <= 60\n  <<\n    Violation: Session timeout must be 60 minutes or less\n    Fix: Set SessionTimeout to 60 or lower\n  >>\n}\n",
              "EnableDebugLogDelivery": true
            }
          },
          "Scope": {
            "ComplianceResourceTypes": [
              "AWS::OpenSearchServerless::SecurityConfig"
            ]
          }
        }
      },
      "OpenSearchAccessControl": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "opensearch-access-control-enabled",
          "Source": {
            "Owner": "AWS",
            "SourceIdentifier": "OPENSEARCH_ACCESS_CONTROL_ENABLED"
          }
        }
      },
      "OpenSearchAuditLogging": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "opensearch-audit-logging-enabled",
          "Source": {
            "Owner": "AWS",
            "SourceIdentifier": "OPENSEARCH_AUDIT_LOGGING_ENABLED"
          }
        }
      },
      "OpenSearchDataNodeFaultTolerance": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "opensearch-data-node-fault-tolerance",
          "Source": {
            "Owner": "AWS",
            "SourceIdentifier": "OPENSEARCH_DATA_NODE_FAULT_TOLERANCE"
          }
        }
      },
      "OpenSearchEncryptedAtRest": {
        "Type": "AWS::Config::ConfigRule",
        "Properties": {
          "ConfigRuleName": "opensearch-encrypted-at-rest",
          "Source": {
            "Owner": "AWS",
            "SourceIdentifier": "OPENSEARCH_ENCRYPTED_AT_REST"
          }
        }
      },
